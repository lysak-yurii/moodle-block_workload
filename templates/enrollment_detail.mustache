{{!
    @template block_workload/enrollment_detail

    Enrollment mode – per-student course management detail view.

    @package   block_workload
    @copyright 2026 Yurii Lysak
    @license   http://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later

    Example context (json):
    {
        "backurl":  "http://example.com/blocks/workload/manage_enrollment.php",
        "backlabel": "Back to student list",
        "statsurl": "http://example.com/blocks/workload/statistics.php",
        "userid": 5,
        "sesskey": "abc123",
        "catformaction": "http://example.com/blocks/workload/manage_enrollment.php",
        "catopts": [
            {"value": 0, "label": "Select category…", "selected": true},
            {"value": 3, "label": "BSc Courses", "selected": false}
        ],
        "selectedcatid": 0,
        "search": "",
        "selectedpage": 0,
        "selectedperpage": 25,
        "pagingbartop": "",
        "pagingbarbottom": "",
        "perpagestr": "Per page",
        "perpageopts": [{"label": "25", "active": true, "islink": false, "url": ""}],
        "hascatresults": false,
        "catresultinfo": "",
        "addcourserows": [],
        "nocoursesincat": false,
        "assignedcount": 3,
        "hascourses": true,
        "nocourses": false,
        "showordercolumn": true,
        "courserows": [
            {
                "id": 10, "name": "Moodle 101", "shortname": "MDL101",
                "courseurl": "http://example.com/course/view.php?id=10",
                "startdate": "01.01.2026", "enddate": "30.06.2026",
                "statuslabel": "Included",
                "statusbadgeclass": "bg-success text-white",
                "actionurl": "http://example.com/blocks/workload/manage_enrollment.php?userid=5&courseid=10&action=exclude",
                "actionlabel": "Exclude",
                "actionbtnclass": "btn-outline-secondary",
                "showup": false,
                "showdown": true,
                "moveupurl": "http://example.com/blocks/workload/manage_enrollment.php?userid=5&moveup=10&sesskey=abc123",
                "movedownurl": "http://example.com/blocks/workload/manage_enrollment.php?userid=5&movedown=10&sesskey=abc123",
                "moveuplabel": "Move up",
                "movedownlabel": "Move down",
                "showordercolumn": true,
                "excluded": false
            }
        ],
        "excludeselected": "Exclude selected",
        "restoreselected": "Restore selected",
        "bulkremovecourses": "Remove selected"
    }
}}

<div class="block_workload-enrollment-detail">

    {{! Top bar: back + statistics }}
    <div class="d-flex justify-content-between align-items-center mb-3">
        <a href="{{{backurl}}}" class="btn btn-outline-secondary">&larr; {{backlabel}}</a>
        <a href="{{{statsurl}}}" class="btn btn-outline-primary">
            {{#str}}statisticstitle, block_workload{{/str}}
        </a>
    </div>

    {{! Add courses panel }}
    <h5 class="mt-2 mb-2">{{#str}}addcoursesforstudent, block_workload{{/str}}</h5>

    {{! Category selector form }}
    <form method="get" action="{{{catformaction}}}" class="mb-3">
        <input type="hidden" name="userid" value="{{userid}}">
        <div class="d-flex align-items-end gap-2 flex-wrap">
            <div class="d-flex flex-column">
                <label for="wl-detail-search" class="form-label small">
                    {{#str}}searchcourses, block_workload{{/str}}
                </label>
                <input type="text" id="wl-detail-search" name="search"
                       class="form-control" style="min-width:220px;"
                       value="{{search}}"
                       placeholder="{{#str}}searchcourses, block_workload{{/str}}">
            </div>
            <div class="d-flex flex-column">
                <label for="wl-catid" class="form-label small">
                    {{#str}}filterbycategory, block_workload{{/str}}
                </label>
                <select name="catid" id="wl-catid"
                        class="select custom-select form-select" style="min-width:260px;">
                    {{#catopts}}
                    <option value="{{value}}"{{#selected}} selected{{/selected}}>{{label}}</option>
                    {{/catopts}}
                </select>
            </div>
            <div class="d-flex flex-column align-self-end">
                <div class="form-check mb-1">
                    <input type="checkbox" class="form-check-input" id="includesubcats"
                           name="includesubcats" value="1"{{#includesubcats}} checked{{/includesubcats}}>
                    <label class="form-check-label small" for="includesubcats">
                        {{#str}}includesubcategories, block_workload{{/str}}
                    </label>
                </div>
                <input type="submit"
                       value="{{#str}}filterresults, block_workload{{/str}}"
                       class="btn btn-secondary">
            </div>
        </div>
    </form>

    {{! Add-courses table (shown when a category is selected) }}
    {{#hascatresults}}
    <p class="small text-muted mb-2">{{catresultinfo}}</p>
    <div class="d-flex justify-content-between align-items-center flex-wrap mb-2">
        <div class="small">
            <span class="font-weight-bold mr-1">{{perpagestr}}:</span>
            {{#perpageopts}}
            {{#islink}}<a href="{{{url}}}" class="mr-1">{{label}}</a>{{/islink}}
            {{^islink}}<span class="mr-1 font-weight-bold">{{label}}</span>{{/islink}}
            {{/perpageopts}}
        </div>
        <div>{{{pagingbartop}}}</div>
    </div>
    <form method="post">
        <input type="hidden" name="userid"         value="{{userid}}">
        <input type="hidden" name="catid"          value="{{selectedcatid}}">
        <input type="hidden" name="includesubcats" value="{{includesubcats}}">
        <input type="hidden" name="search"         value="{{search}}">
        <input type="hidden" name="page"           value="{{selectedpage}}">
        <input type="hidden" name="perpage"        value="{{selectedperpage}}">
        <input type="hidden" name="sesskey"        value="{{sesskey}}">
        <input type="hidden" name="bulkaddcourses" value="1">
        <table class="generaltable table-sm table-hover mb-3">
            <thead>
                <tr>
                    <th class="c0 shrink">
                        <input type="checkbox"
                               id="wl-addcourses-master"
                               data-action="toggle"
                               data-togglegroup="wl-addcourses-group"
                               data-toggle="toggler"
                               title="{{#str}}selectall{{/str}}"
                               checked>
                    </th>
                    <th>{{#str}}course, block_workload{{/str}}</th>
                    <th>{{#str}}coursestartdate, block_workload{{/str}}</th>
                    <th>{{#str}}courseenddate, block_workload{{/str}}</th>
                </tr>
            </thead>
            <tbody>
                {{#addcourserows}}
                <tr{{#already}} class="text-muted"{{/already}}>
                    <td class="c0 shrink">
                        {{#already}}
                        <span class="text-success fw-bold" title="{{alreadytitle}}">&#10003;</span>
                        {{/already}}
                        {{^already}}
                        <input type="checkbox"
                               name="addcourseids[]"
                               value="{{id}}"
                               checked
                               data-action="toggle"
                               data-togglegroup="wl-addcourses-group"
                               data-toggle="target">
                        {{/already}}
                    </td>
                    <td>
                        <a href="{{{courseurl}}}" target="_blank">{{name}}</a>
                        <span class="text-muted small"> ({{shortname}})</span>
                    </td>
                    <td>{{startdate}}</td>
                    <td>{{enddate}}</td>
                </tr>
                {{/addcourserows}}
            </tbody>
        </table>
        {{{pagingbarbottom}}}
        <button type="submit" class="btn btn-primary">
            {{#str}}addcourses, block_workload{{/str}}
        </button>
    </form>
    {{/hascatresults}}

    {{#nocoursesincat}}
    <div class="alert alert-info" role="alert">
        {{#str}}notargetcourses, block_workload{{/str}}
    </div>
    {{/nocoursesincat}}

    {{! Assigned courses table }}
    <h5 class="mt-4 mb-2">{{#str}}assignedcourses, block_workload{{/str}}{{#hascourses}} <span class="text-muted fw-normal small ms-1">({{assignedcount}})</span>{{/hascourses}}</h5>

    {{#nocourses}}
    <div class="text-muted small mb-3">
        {{#str}}noenrolledcourses, block_workload{{/str}}
    </div>
    {{/nocourses}}

    {{#hascourses}}
    <form method="post" id="wl-assigned-form">
        <input type="hidden" name="userid"  value="{{userid}}">
        <input type="hidden" name="sesskey" value="{{sesskey}}">
        <table class="generaltable table-sm table-striped table-hover mb-2">
            <thead>
                <tr>
                    <th class="c0 shrink">
                        <input type="checkbox"
                               id="wl-assigned-master"
                               data-action="toggle"
                               data-togglegroup="wl-assigned-group"
                               data-toggle="toggler"
                               title="{{#str}}selectall{{/str}}">
                    </th>
                    <th>{{#str}}course, block_workload{{/str}}</th>
                    <th>{{#str}}coursestartdate, block_workload{{/str}}</th>
                    <th>{{#str}}courseenddate, block_workload{{/str}}</th>
                    <th>{{#str}}activecourse, block_workload{{/str}}</th>
                    {{#showordercolumn}}<th>{{#str}}order, moodle{{/str}}</th>{{/showordercolumn}}
                    <th>{{#str}}actions, block_workload{{/str}}</th>
                </tr>
            </thead>
            <tbody>
                {{#courserows}}
                <tr{{#excluded}} class="text-muted"{{/excluded}}>
                    <td class="c0 shrink">
                        <input type="checkbox"
                               name="courseids[]"
                               value="{{id}}"
                               data-action="toggle"
                               data-togglegroup="wl-assigned-group"
                               data-toggle="target">
                    </td>
                    <td>
                        <a href="{{{courseurl}}}" target="_blank"{{#excluded}} class="text-muted"{{/excluded}}>{{name}}</a>
                        <span class="text-muted small"> ({{shortname}})</span>
                    </td>
                    <td{{#startdatealert}} class="text-danger fw-bold"{{/startdatealert}}>{{startdate}}</td>
                    <td{{#enddatealert}} class="text-danger fw-bold"{{/enddatealert}}>{{enddate}}</td>
                    <td>
                        <span class="badge {{statusbadgeclass}}">{{statuslabel}}</span>
                        {{#datehidden}} <span class="badge bg-warning text-dark" title="{{datewarntitle}}">{{datewarnlabel}}</span>{{/datehidden}}
                    </td>
                    {{#showordercolumn}}
                    <td>
                        {{#showup}}
                        <a href="{{{moveupurl}}}" title="{{moveuplabel}}">
                            {{#pix}}t/up, core, {{moveuplabel}}{{/pix}}
                        </a>
                        {{/showup}}
                        {{^showup}}<span style="display:inline-block;width:1.4rem;"></span>{{/showup}}
                        {{#showdown}}
                        <a href="{{{movedownurl}}}" title="{{movedownlabel}}">
                            {{#pix}}t/down, core, {{movedownlabel}}{{/pix}}
                        </a>
                        {{/showdown}}
                        {{^showdown}}<span style="display:inline-block;width:1.4rem;"></span>{{/showdown}}
                    </td>
                    {{/showordercolumn}}
                    <td><a href="{{{actionurl}}}" class="btn {{actionbtnclass}} btn-sm">{{actionlabel}}</a></td>
                </tr>
                {{/courserows}}
            </tbody>
        </table>

        <button type="submit" name="bulkaction" value="exclude"
                class="btn btn-secondary me-2" disabled>
            {{excludeselected}}
        </button>
        <button type="submit" name="bulkaction" value="restore"
                class="btn btn-secondary me-2" disabled>
            {{restoreselected}}
        </button>
        <button type="submit" name="bulkaction" value="remove"
                class="btn btn-secondary" disabled>
            {{bulkremovecourses}}
        </button>
    </form>
    {{/hascourses}}

</div>
