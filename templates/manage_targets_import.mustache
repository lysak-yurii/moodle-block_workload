{{!
    @template block_workload/manage_targets_import

    Import preview: categorised rows and a confirm/cancel step. Nothing has
    been written yet when this renders.

    @package   block_workload
    @copyright 2026 Yurii Lysak
    @license   http://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later

    Example context (json):
    {
        "summary": "2 new, 1 changed, 3 unchanged, 0 cleared, 1 unmatched, 0 invalid",
        "haschanges": true,
        "nochanges": false,
        "rows": [{"line": 2, "identifier": "12", "coursename": "Course A",
                  "oldtarget": "", "newtarget": "150.0",
                  "status": "new", "statuslabel": "New", "badgeclass": "text-bg-success"}],
        "payload": "[{\"c\":12,\"h\":150}]",
        "formaction": "http://example.com/blocks/workload/manage_targets.php",
        "sesskey": "abc",
        "cancelurl": "http://example.com/blocks/workload/manage_targets.php"
    }
}}

<div class="block_workload-targets-import-preview">

    <h4>{{#str}}importpreviewheading, block_workload{{/str}}</h4>
    <p class="text-muted">{{summary}}</p>

    <div class="table-responsive mb-3">
        <table class="table table-sm align-middle">
            <thead>
                <tr>
                    <th scope="col">#</th>
                    <th scope="col">{{#str}}importcolidentifier, block_workload{{/str}}</th>
                    <th scope="col">{{#str}}course{{/str}}</th>
                    <th scope="col">{{#str}}importcolold, block_workload{{/str}}</th>
                    <th scope="col">{{#str}}importcolnew, block_workload{{/str}}</th>
                    <th scope="col">{{#str}}status{{/str}}</th>
                </tr>
            </thead>
            <tbody>
                {{#rows}}
                <tr>
                    <td class="text-muted small">{{line}}</td>
                    <td>{{identifier}}</td>
                    <td>{{coursename}}</td>
                    <td>{{oldtarget}}</td>
                    <td>{{newtarget}}</td>
                    <td><span class="badge {{badgeclass}}">{{statuslabel}}</span></td>
                </tr>
                {{/rows}}
            </tbody>
        </table>
    </div>

    {{#nochanges}}
    <p class="alert alert-info">{{#str}}importnochanges, block_workload{{/str}}</p>
    {{/nochanges}}

    <div class="d-flex gap-2">
        {{#haschanges}}
        <form method="post" action="{{{formaction}}}">
            <input type="hidden" name="applyimport" value="1">
            <input type="hidden" name="sesskey" value="{{sesskey}}">
            <input type="hidden" name="payload" value="{{payload}}">
            <button type="submit" class="btn btn-primary">{{#str}}importconfirm, block_workload{{/str}}</button>
        </form>
        {{/haschanges}}
        <a href="{{{cancelurl}}}" class="btn btn-outline-secondary">{{#str}}cancel{{/str}}</a>
    </div>

</div>
