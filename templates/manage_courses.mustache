{{!
    @template block_workload/manage_courses

    Manage-courses page body (action=courses).

    Context variables – see action_courses() in manage.php.

    Example context (json):
    {
        "backurl": "#", "cohortid": 1, "sesskey": "abc",
        "selectedcategory": 0,
        "search": "",
        "selectedpage": 0,
        "selectedperpage": 25,
        "pagingbartop": "",
        "pagingbarbottom": "",
        "perpagestr": "Per page",
        "perpageopts": [{"label": "25", "active": true, "islink": false, "url": ""}],
        "catopts": [{"value":"0","text":"Select category","selected":true}],
        "hascatcourses": false, "nocatcourses": false,
        "catresultinfo": "", "catrows": [],
        "showordercolumn": true,
        "hasassigned": false,
        "assignedcount": 0,
        "assignedrows": []
    }
}}

<a href="{{{backurl}}}" class="btn btn-outline-secondary mb-3">
    &larr; {{#str}}cohorts, block_workload{{/str}}
</a>

{{! ── Add courses: category browser ─────────────────────────────────── }}
<h5>{{#str}}addcourses, block_workload{{/str}}</h5>

<form method="get"      class="d-flex gap-2 align-items-end flex-wrap mb-3">
    <input type="hidden" name="action" value="courses">
    <input type="hidden" name="id" value="{{cohortid}}">

    <div class="d-flex flex-column">
        <label for="wl-courses-search" class="form-label small">
            {{#str}}searchcourses, block_workload{{/str}}
        </label>
        <input type="text" id="wl-courses-search" name="search"
               class="form-control" style="min-width:220px;"
               value="{{search}}"
               placeholder="{{#str}}searchcourses, block_workload{{/str}}">
    </div>

    <div class="d-flex flex-column">
        <label for="catsel" class="form-label small">
            {{#str}}filterbycategory, block_workload{{/str}}
        </label>
        <select name="categoryid" id="catsel"
                class="select custom-select form-select" style="min-width:250px;">
            {{#catopts}}
            <option value="{{value}}"{{#selected}} selected{{/selected}}>{{{text}}}</option>
            {{/catopts}}
        </select>
    </div>

    <div class="d-flex flex-column align-self-end">
        <div class="form-check mb-1">
            <input type="checkbox" class="form-check-input" id="includesubcats"
                   name="includesubcats" value="1"{{#includesubcats}} checked{{/includesubcats}}>
            <label class="form-check-label small" for="includesubcats">
                {{#str}}includesubcategories, block_workload{{/str}}
            </label>
        </div>
        <input type="submit"
               value="{{#str}}filterresults, block_workload{{/str}}"
               class="btn btn-secondary">
    </div>
</form>

{{#nocatcourses}}
<p class="text-muted">{{#str}}notargetcourses, block_workload{{/str}}</p>
{{/nocatcourses}}

{{#hascatcourses}}
<p class="text-muted small mb-2">{{{catresultinfo}}}</p>

<div class="d-flex justify-content-between align-items-center flex-wrap mb-2">
    <div class="small">
        <span class="font-weight-bold mr-1">{{perpagestr}}:</span>
        {{#perpageopts}}
        {{#islink}}<a href="{{{url}}}" class="mr-1">{{label}}</a>{{/islink}}
        {{^islink}}<span class="mr-1 font-weight-bold">{{label}}</span>{{/islink}}
        {{/perpageopts}}
    </div>
    <div>{{{pagingbartop}}}</div>
</div>

<form method="post" id="wl-addcourses-form">
    <input type="hidden" name="action" value="courses">
    <input type="hidden" name="id" value="{{cohortid}}">
    <input type="hidden" name="categoryid"     value="{{selectedcategory}}">
    <input type="hidden" name="includesubcats" value="{{includesubcats}}">
    <input type="hidden" name="search"         value="{{search}}">
    <input type="hidden" name="page"           value="{{selectedpage}}">
    <input type="hidden" name="perpage"        value="{{selectedperpage}}">
    <input type="hidden" name="sesskey" value="{{sesskey}}">

    <table class="generaltable table-sm table-hover">
        <thead>
            <tr>
                <th class="c0 shrink" scope="col">
                    <input type="checkbox"
                           id="wl-addcourses-master"
                           data-action="toggle"
                           data-togglegroup="addcourses-group"
                           data-toggle="toggler"
                           title="{{#str}}selectall{{/str}}"
                           checked>
                </th>
                <th scope="col">{{#str}}course, block_workload{{/str}}</th>
                <th scope="col">{{#str}}coursestartdate, block_workload{{/str}}</th>
                <th scope="col">{{#str}}courseenddate, block_workload{{/str}}</th>
            </tr>
        </thead>
        <tbody>
            {{#catrows}}
            <tr{{#already}} class="text-muted"{{/already}}>
                <td class="c0 shrink">
                    {{#already}}
                    <span class="text-success fw-bold"
                          title="{{#str}}alreadymember, block_workload{{/str}}">&#10003;</span>
                    {{/already}}
                    {{^already}}
                    <input type="checkbox"
                           name="addcourseids[]"
                           value="{{id}}"
                           checked
                           data-action="toggle"
                           data-togglegroup="addcourses-group"
                           data-toggle="target">
                    {{/already}}
                </td>
                <td>
                    <a href="{{{courseurl}}}" target="_blank">{{{fullname}}}</a>
                    <span class="text-muted small"> ({{shortname}})</span>
                </td>
                <td>
                    {{#startdate_disabled}}<span class="text-muted small">{{{datedisabled}}}</span>{{/startdate_disabled}}
                    {{^startdate_disabled}}{{startdate}}{{/startdate_disabled}}
                </td>
                <td>
                    {{#enddate_disabled}}<span class="text-muted small">{{{datedisabled}}}</span>{{/enddate_disabled}}
                    {{^enddate_disabled}}{{enddate}}{{/enddate_disabled}}
                </td>
            </tr>
            {{/catrows}}
        </tbody>
    </table>
    {{{pagingbarbottom}}}

    <button type="submit" class="btn btn-primary" disabled>
        {{#str}}addcourses, block_workload{{/str}}
    </button>
</form>
{{/hascatcourses}}

{{! ── Assigned courses ───────────────────────────────────────────────── }}
<h5 class="mt-4">
    {{#str}}assignedcourses, block_workload{{/str}}
    {{#hasassigned}}
    <span class="text-muted fw-normal small ms-1">({{assignedcount}})</span>
    {{/hasassigned}}
</h5>

{{^hasassigned}}
<p class="text-muted">{{#str}}nocoursesincategory, block_workload{{/str}}</p>
{{/hasassigned}}

{{#hasassigned}}
<form method="post" id="wl-removecourses-form">
    <input type="hidden" name="action" value="courses">
    <input type="hidden" name="id" value="{{cohortid}}">
    <input type="hidden" name="sesskey" value="{{sesskey}}">

    <table class="generaltable table-sm table-striped">
        <thead>
            <tr>
                <th class="c0 shrink" scope="col">
                    <input type="checkbox"
                           id="wl-courses-remove-master"
                           data-action="toggle"
                           data-togglegroup="removecourses-group"
                           data-toggle="toggler"
                           title="{{#str}}selectall{{/str}}">
                </th>
                <th scope="col">{{#str}}course, block_workload{{/str}}</th>
                <th scope="col">{{#str}}coursestartdate, block_workload{{/str}}</th>
                <th scope="col">{{#str}}courseenddate, block_workload{{/str}}</th>
                <th scope="col">{{#str}}activecourse, block_workload{{/str}}</th>
                {{#showordercolumn}}
                <th scope="col">{{#str}}order, block_workload{{/str}}</th>
                {{/showordercolumn}}
                <th scope="col">{{#str}}actions, block_workload{{/str}}</th>
            </tr>
        </thead>
        <tbody>
            {{#assignedrows}}
            <tr{{^active}} class="text-muted"{{/active}}>
                <td class="c0 shrink">
                    <input type="checkbox"
                           name="removecourseids[]"
                           value="{{assignid}}"
                           data-action="toggle"
                           data-togglegroup="removecourses-group"
                           data-toggle="target">
                </td>
                <td>
                    <a href="{{{courseurl}}}" target="_blank"{{^active}} class="text-muted"{{/active}}>{{{fullname}}}</a>
                    <span class="text-muted small"> ({{shortname}})</span>
                </td>
                <td>
                    {{#startdate_disabled}}<span class="text-muted small">{{{datedisabled}}}</span>{{/startdate_disabled}}
                    {{^startdate_disabled}}{{startdate}}{{/startdate_disabled}}
                </td>
                <td>
                    {{#enddate_disabled}}<span class="text-muted small">{{{datedisabled}}}</span>{{/enddate_disabled}}
                    {{^enddate_disabled}}{{enddate}}{{/enddate_disabled}}
                </td>
                <td>
                    <a href="{{{toggleurl}}}" title="{{togglelabel}}">
                        {{#active}}{{#pix}}t/hide, core, {{togglelabel}}{{/pix}}{{/active}}
                        {{^active}}{{#pix}}t/show, core, {{togglelabel}}{{/pix}}{{/active}}
                    </a>
                </td>
                {{#showordercolumn}}
                <td>
                    {{#showup}}
                    <a href="{{{moveupurl}}}" title="{{moveuplabel}}">
                        {{#pix}}t/up, core, {{moveuplabel}}{{/pix}}
                    </a>
                    {{/showup}}
                    {{^showup}}<span style="display:inline-block;width:1.4rem;"></span>{{/showup}}
                    {{#showdown}}
                    <a href="{{{movedownurl}}}" title="{{movedownlabel}}">
                        {{#pix}}t/down, core, {{movedownlabel}}{{/pix}}
                    </a>
                    {{/showdown}}
                    {{^showdown}}<span style="display:inline-block;width:1.4rem;"></span>{{/showdown}}
                </td>
                {{/showordercolumn}}
                <td>
                    <a href="{{{confirmremoveurl}}}"
                       title="{{#str}}removecourse, block_workload{{/str}}">
                        {{#pix}}t/delete, core, {{#str}}removecourse, block_workload{{/str}}{{/pix}}
                    </a>
                </td>
            </tr>
            {{/assignedrows}}
        </tbody>
    </table>

    <button type="submit" class="btn btn-secondary mt-2" disabled>
        {{#str}}bulkremovecourses, block_workload{{/str}}
    </button>
</form>
{{/hasassigned}}
