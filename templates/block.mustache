{{!
    @template block_workload/block

    Workload Assessment student block showing weekly hours per course.

    @package   block_workload
    @copyright 2026 Yurii Lysak
    @license   http://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later

    Example context (json):
    {
        "courses": [{"courseid": 1, "coursename": "Moodle 101", "courseurl": "http://example.com/", "hours_display": "2:30", "hours_raw": 2.5, "not_entered": false, "maxhours": 40, "hourstep": 0.25, "initiallyhidden": false}],
        "weeknumber": 22,
        "year": 2026,
        "weeknumber_tooltip": "Calendar week 22, 2026",
        "mystatsurl": "http://example.com/blocks/workload/mystats.php",
        "hascourses": true,
        "haspagination": false,
        "hourstep": 0.25
    }
}}

<div class="block-workload">

    {{! Week header }}
    <div class="workload-header d-flex justify-content-between align-items-center px-3 py-2 rounded-top bg-primary text-white">
        <div class="d-flex align-items-center">
            <span class="fw-semibold small"
                  title="{{#str}}blocktitle_tooltip, block_workload{{/str}}"
                  style="cursor:help;">{{#str}}blocktitle, block_workload{{/str}}</span>
            <button type="button"
                    class="workload-help-btn btn p-0 ms-2 text-white rounded-circle"
                    style="width:.9rem;height:.9rem;font-size:.6rem;line-height:1;opacity:.7;border:1px solid rgba(255,255,255,.6);flex-shrink:0;cursor:help;"
                    title="{{#str}}blocktitle_tooltip, block_workload{{/str}}"
                    aria-label="{{#str}}blocktitle_tooltip, block_workload{{/str}}">?</button>
        </div>
        <span class="badge rounded-pill text-bg-secondary ms-2"
              title="{{weeknumber_tooltip}}"
              style="cursor:help;">{{#str}}weeknumber, block_workload, {{weeknumber}}{{/str}}</span>
    </div>

    {{#hascourses}}
    {{! Column headers }}
    <div class="workload-colheader px-3 py-1 border-bottom bg-light">
        <span class="text-muted small fw-semibold">{{#str}}columnlecture, block_workload{{/str}}</span>
        <div class="d-flex align-items-center" style="gap:.25rem;">
            <span style="display:inline-block;width:1.4rem;flex-shrink:0;"></span>
            <span class="text-muted small fw-semibold" style="width:3.2rem;text-align:center;">{{#str}}columnhours, block_workload{{/str}}</span>
            <span style="display:inline-block;width:1.4rem;flex-shrink:0;"></span>
        </div>
    </div>

    {{! Course rows }}
    {{#courses}}
    <div class="workload-course-row px-3 py-2 border-bottom{{#not_entered}} workload-not-entered{{/not_entered}}"
         data-courseid="{{courseid}}"{{#initiallyhidden}} style="display:none!important"{{/initiallyhidden}}>

        {{! Course name }}
        <div class="workload-course-name text-truncate me-2" style="min-width:0;">
            <a href="{{courseurl}}" class="text-decoration-none small" title="{{coursename}}">{{coursename}}</a>
        </div>

        {{! Hours control }}
        <div class="workload-hours-control d-flex align-items-center gap-1">

            <button type="button"
                    class="workload-btn-minus btn btn-sm btn-outline-secondary rounded-circle"
                    style="width:1.4rem;height:1.4rem;padding:0;line-height:1;font-size:.75rem;"
                    aria-label="{{#str}}decrease, block_workload{{/str}}">&#8722;</button>

            <input type="text"
                   class="workload-hours-input form-control form-control-sm text-center"
                   style="width:3.2rem;font-size:.8rem;padding:.15rem .25rem;"
                   value="{{hours_display}}"
                   data-hours="{{hours_raw}}"
                   data-step="{{hourstep}}"
                   data-max="{{maxhours}}"
                   placeholder="0:00"
                   aria-label="{{#str}}hours, block_workload{{/str}}">

            <button type="button"
                    class="workload-btn-plus btn btn-sm btn-primary rounded-circle"
                    style="width:1.4rem;height:1.4rem;padding:0;line-height:1;font-size:.75rem;"
                    aria-label="{{#str}}increase, block_workload{{/str}}">+</button>
        </div>
    </div>
    {{/courses}}

    {{#haspagination}}
    <div class="workload-pagination d-flex justify-content-between align-items-center px-3 py-2 border-top bg-light">
        <button type="button"
                class="workload-btn-prev btn btn-sm btn-outline-secondary"
                style="padding:0 .45rem;font-size:.8rem;"
                aria-label="{{#str}}pageprev, block_workload{{/str}}"
                disabled>&#8592;</button>
        <span class="workload-page-info small text-muted"></span>
        <button type="button"
                class="workload-btn-next btn btn-sm btn-outline-secondary"
                style="padding:0 .45rem;font-size:.8rem;"
                aria-label="{{#str}}pagenext, block_workload{{/str}}">&#8594;</button>
    </div>
    {{/haspagination}}

    {{/hascourses}}


</div>
