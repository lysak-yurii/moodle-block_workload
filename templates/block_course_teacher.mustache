{{!
    @template block_workload/block_course_teacher

    In-course Workload widget as teaching staff see it: a read-only summary of
    what the students of this course recorded. Teachers do not record hours, so
    there is no stepper and no week navigation — the figures are all-time and
    match the course statistics report the footer links to.

    @package   block_workload
    @copyright 2026 Yurii Lysak
    @license   http://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later

    Example context (json):
    {
        "blocktitle_tooltip": "Overview of the hours your students recorded for this course.",
        "recordingtext": "12 / 30",
        "totalhours": "248.0",
        "avghours": "20.7"
    }
}}

<div class="block-workload block-workload-course block-workload-teacher">

    {{! Title header — no week nav: nothing here is week-scoped. }}
    <div class="workload-header d-flex justify-content-between align-items-center px-3 py-2 rounded-top bg-primary text-white">
        <div class="d-flex align-items-center">
            <span class="fw-semibold small"
                  title="{{blocktitle_tooltip}}"
                  style="cursor:help;">{{#str}}blocktitle_teacher, block_workload{{/str}}</span>
            <button type="button"
                    class="workload-help-btn btn p-0 ms-2 text-white rounded-circle"
                    style="width:.9rem;height:.9rem;font-size:.6rem;line-height:1;opacity:.7;border:1px solid rgba(255,255,255,.6);flex-shrink:0;cursor:help;"
                    title="{{blocktitle_tooltip}}"
                    aria-label="{{blocktitle_tooltip}}">?</button>
        </div>
    </div>

    {{! Read-only course figures. }}
    <div class="workload-teacher-stats px-3 py-2">
        <div class="d-flex justify-content-between align-items-center mb-1">
            <span class="small text-muted me-2">{{#str}}studentsrecording, block_workload{{/str}}</span>
            <span class="small fw-semibold text-nowrap">{{recordingtext}}</span>
        </div>
        <div class="d-flex justify-content-between align-items-center mb-1">
            <span class="small text-muted me-2">{{#str}}totalhours, block_workload{{/str}}</span>
            <span class="small fw-semibold text-nowrap">{{totalhours}}</span>
        </div>
        <div class="d-flex justify-content-between align-items-center">
            <span class="small text-muted me-2">{{#str}}avghrsperstudent, block_workload{{/str}}</span>
            <span class="small fw-semibold text-nowrap">{{avghours}}</span>
        </div>
    </div>

</div>
