{{!
    @template block_workload/block_course

    In-course Workload widget: log hours for this course for the viewed week
    and see cumulative progress against the course's target hours.

    @package   block_workload
    @copyright 2026 Yurii Lysak
    @license   http://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later

    Example context (json):
    {
        "courseid": 12,
        "hours_display": "2:30",
        "hours_raw": 2.5,
        "not_entered": false,
        "maxhours": 40,
        "hourstep": 0.25,
        "weeknumber": 22,
        "year": 2026,
        "weeknumber_tooltip": "Calendar week 22, 2026",
        "blocktitle_tooltip": "Log the hours you spent on this course.",
        "hasweeknav": true,
        "prevdisabled": false,
        "nextdisabled": false,
        "hastarget": true,
        "target_raw": 150,
        "percent": 28,
        "progresstext": "42.0 / 150.0 h · 28%"
    }
}}

<div class="block-workload block-workload-course">

    {{! Week header }}
    <div class="workload-header d-flex justify-content-between align-items-center px-3 py-2 rounded-top bg-primary text-white">
        <div class="d-flex align-items-center">
            <span class="fw-semibold small"
                  title="{{blocktitle_tooltip}}"
                  style="cursor:help;">{{#str}}blocktitle, block_workload{{/str}}</span>
            <button type="button"
                    class="workload-help-btn btn p-0 ms-2 text-white rounded-circle"
                    style="width:.9rem;height:.9rem;font-size:.6rem;line-height:1;opacity:.7;border:1px solid rgba(255,255,255,.6);flex-shrink:0;cursor:help;"
                    title="{{blocktitle_tooltip}}"
                    aria-label="{{blocktitle_tooltip}}">?</button>
        </div>
        <div class="workload-week-nav d-flex align-items-center ms-2" style="gap:.15rem;">
            {{#hasweeknav}}
            <button type="button"
                    class="workload-week-prev"
                    style="background:none;border:0;padding:0 .1rem;color:#fff;cursor:pointer;font-size:.65rem;line-height:1;opacity:.8;{{#prevdisabled}}visibility:hidden;{{/prevdisabled}}"
                    aria-label="{{#str}}prevweek, block_workload{{/str}}"
                    title="{{#str}}prevweek, block_workload{{/str}}"
                    {{#prevdisabled}}disabled{{/prevdisabled}}>&#9666;</button>
            {{/hasweeknav}}
            <span class="workload-week-badge badge rounded-pill text-bg-secondary"
                  title="{{weeknumber_tooltip}}"
                  style="cursor:help;">{{#str}}weeknumber, block_workload, {{weeknumber}}{{/str}}</span>
            {{#hasweeknav}}
            <button type="button"
                    class="workload-week-next"
                    style="background:none;border:0;padding:0 .1rem;color:#fff;cursor:pointer;font-size:.65rem;line-height:1;opacity:.8;{{#nextdisabled}}visibility:hidden;{{/nextdisabled}}"
                    aria-label="{{#str}}nextweek, block_workload{{/str}}"
                    title="{{#str}}nextweek, block_workload{{/str}}"
                    {{#nextdisabled}}disabled{{/nextdisabled}}>&#9656;</button>
            {{/hasweeknav}}
        </div>
    </div>

    {{! Single-course hours row (same classes as the dashboard so workload.js applies) }}
    <div class="workload-course-row px-3 py-2 border-bottom{{#not_entered}} workload-not-entered{{/not_entered}}"
         data-courseid="{{courseid}}">

        <div class="workload-course-name text-truncate me-2" style="min-width:0;">
            <span class="small text-muted">{{#str}}thisweeklabel, block_workload{{/str}}</span>
        </div>

        <div class="workload-hours-control d-flex align-items-center gap-1">

            <button type="button"
                    class="workload-btn-minus btn btn-sm btn-outline-secondary rounded-circle"
                    style="width:1.4rem;height:1.4rem;padding:0;line-height:1;font-size:.75rem;"
                    aria-label="{{#str}}decrease, block_workload{{/str}}">&#8722;</button>

            <input type="text"
                   class="workload-hours-input form-control form-control-sm text-center"
                   style="width:3.2rem;font-size:.8rem;padding:.15rem .25rem;"
                   value="{{hours_display}}"
                   data-hours="{{hours_raw}}"
                   data-step="{{hourstep}}"
                   data-max="{{maxhours}}"
                   placeholder="0:00"
                   aria-label="{{#str}}hours, block_workload{{/str}}">

            <button type="button"
                    class="workload-btn-plus btn btn-sm btn-primary rounded-circle"
                    style="width:1.4rem;height:1.4rem;padding:0;line-height:1;font-size:.75rem;"
                    aria-label="{{#str}}increase, block_workload{{/str}}">+</button>
        </div>
    </div>

    {{#hastarget}}
    {{! Cumulative progress against the course target }}
    <div class="workload-progress px-3 py-2">
        <div class="d-flex justify-content-between align-items-center mb-1">
            <span class="small text-muted">{{#str}}progresslabel, block_workload{{/str}}</span>
            <span class="workload-progress-text small fw-semibold" data-target="{{target_raw}}">{{progresstext}}</span>
        </div>
        <div class="progress" style="height:.5rem;">
            <div class="progress-bar workload-progress-bar"
                 role="progressbar"
                 style="width:{{percent}}%;"
                 aria-valuenow="{{percent}}"
                 aria-valuemin="0"
                 aria-valuemax="100"></div>
        </div>
    </div>
    {{/hastarget}}

</div>
